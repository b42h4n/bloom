# !/usr/bin/env python3

import os
from prompt_toolkit import *
from prompt_toolkit.key_binding import KeyBindings
import argparse
from colorama import *

#init
def arguments():
    parser = argparse.ArgumentParser(description="Argument check")
    parser.add_argument('my_arg', nargs='?', default=None)
    
    args = parser.parse_args()

    if args.my_arg is not None:
        return args.my_arg
    else:
        return False
if arguments():
    args=arguments()
else:
    args=""

os.system("clear")
lines=[]
text=""
version="1.2.1"
tabs=[args] if args else ["new tab"]
print(f"{Fore.BLACK + Back.WHITE}Bloom {version}    {'  '.join(tabs)}{' '*int((os.get_terminal_size().columns)-21)}{Fore.RESET}")
#keybinds
kb = KeyBindings()
@kb.add("c-s")
def save_and_exit(event):
    event.app.exit(result=event.app.current_buffer.text)
@kb.add("c-c")
def exit_no_save(event):
    event.app.exit(result=None)

#typing
if not args:
    text = prompt("", multiline=True, key_bindings=kb)
else:
    try:
        with open(args, "r", encoding="utf-8") as f:
            file_content = f.read()
        text = prompt("", default=file_content, multiline=True, key_bindings=kb)
    except FileNotFoundError:
        with open(args, "w", encoding="utf-8") as f:
                text = prompt("", multiline=True, key_bindings=kb)

#saving
if text:
    lines.append(text)
    file=prompt("Save to file: ", default=args,multiline=False, key_bindings=None)
    try:
        with open(file, "w", encoding="utf-8") as save:
            for i in lines:
                save.write(i)
            save.write("\n")
    except FileNotFoundError:
        pass
