#!/usr/bin/env python3
import os
import argparse
from colorama import Fore, Back, init
from prompt_toolkit import prompt
from prompt_toolkit.key_binding import KeyBindings
from prompt_toolkit.formatted_text import FormattedText
from prompt_toolkit.layout.controls import FormattedTextControl
from prompt_toolkit.layout.containers import Window, HSplit, VSplit
from prompt_toolkit.layout.layout import Layout
from prompt_toolkit.layout.margins import Margin
from prompt_toolkit.widgets import TextArea
from prompt_toolkit.application import Application
from prompt_toolkit.document import Document
from prompt_toolkit.styles import Style

init(autoreset=True)
def arguments():
    parser = argparse.ArgumentParser(description="Argument check")
    parser.add_argument('my_arg', nargs='?', default=None)
    args = parser.parse_args()
    return args.my_arg if args.my_arg else None

tabs = {}
tab_order = []
current_idx = 0
version = "1.4"
running = True

initial_arg = arguments()
if initial_arg:
    if os.path.exists(initial_arg):
        try:
            with open(initial_arg, "r", encoding="utf-8") as f:
                tabs[initial_arg] = f.read()
        except Exception:
            tabs[initial_arg] = ""
    else:
        tabs[initial_arg] = ""
    tab_order.append(initial_arg)
else:
    tabs["new tab"] = ""
    tab_order.append("new tab")

# status bar

def make_status_bar(text_area):
    def get_tokens():
        doc = text_area.document
        row = doc.cursor_position_row + 1
        col = doc.cursor_position_col + 1
        total_lines = len(doc.lines)
        tab_name = tab_order[current_idx]
        modified = "*" if tabs.get(tab_name, "") != text_area.text else ""

        parts = [
            ("class:status-bar",       f" {modified}{tab_name}  "),
            ("class:status-bar.key",   " ^S"),
            ("class:status-bar",       " - Save  "),
            ("class:status-bar.key",   "^T"),
            ("class:status-bar",       " - New Tab  "),
            ("class:status-bar.key",   "^P"),
            ("class:status-bar",       " - Next Tab  "),
            ("class:status-bar.key",   "^Q"),
            ("class:status-bar",       " - Quit"),
            ("class:status-bar",       " " * 4),
            ("class:status-bar",       f"Ln {row}/{total_lines}  Col {col} "),
        ]
        return FormattedText(parts)

    return get_tokens

def render_tab_line():
    rendered_tabs = []
    for i, tab_name in enumerate(tab_order):
        if i == current_idx:
            rendered_tabs.append(f"{Fore.BLACK + Back.GREEN} {tab_name} {Fore.RESET + Back.RESET}")
        else:
            rendered_tabs.append(f"{Fore.WHITE + Back.BLACK} {tab_name} {Fore.RESET + Back.RESET}")
    tab_line = "  ".join(rendered_tabs)
    raw_len = len("  ".join(tab_order)) + (len(tab_order) * 2)
    padding = max(0, os.get_terminal_size().columns - 15 - raw_len)
    print(
        f"{Fore.BLACK + Back.WHITE}Bloom {version}"
        f"  {Fore.RESET + Back.RESET}{tab_line}"
        f"{Back.WHITE}{' ' * padding}{Fore.RESET + Back.RESET}"
    )


# main loop

while running:
    os.system("clear")
    render_tab_line()

    current_tab_name = tab_order[current_idx]
    current_text = tabs[current_tab_name]

    text_area = TextArea(
        text=current_text,
        multiline=True,
        scrollbar=True,
        line_numbers=True,
        style="class:text-area",
    )

    status_bar = Window(
        content=FormattedTextControl(make_status_bar(text_area)),
        height=1,
        style="class:status-bar",
    )

    layout = Layout(
        HSplit([
            text_area,
            status_bar,
        ]),
        focused_element=text_area,
    )

    kb = KeyBindings()

    @kb.add("c-s")
    def save_current_tab(event):
        current_tab = tab_order[current_idx]
        current_content = text_area.text
        tabs[current_tab] = current_content
        if "new tab" in current_tab:
            event.app.exit(result=("save_new", current_content))
        else:
            try:
                with open(current_tab, "w", encoding="utf-8") as f:
                    f.write(current_content)
                    if not current_content.endswith("\n"):
                        f.write("\n")
                event.app.exit(result="refresh")
            except Exception:
                event.app.exit(result="refresh")

    @kb.add("c-q")
    def exit_editor(event):
        global running
        running = False
        event.app.exit(result="exit")

    @kb.add("c-c")
    def exit_no_save(event):
        global running
        running = False
        event.app.exit(result=None)

    @kb.add("c-t")
    def new_tab(event):
        global current_idx
        tabs[tab_order[current_idx]] = text_area.text
        new_name = f"new tab {len(tabs) + 1}"
        tabs[new_name] = ""
        tab_order.append(new_name)
        current_idx = len(tab_order) - 1
        event.app.exit(result="switch")

    @kb.add("c-p")
    def next_tab(event):
        global current_idx
        if len(tab_order) <= 1:
            return
        tabs[tab_order[current_idx]] = text_area.text
        current_idx = (current_idx + 1) % len(tab_order)
        event.app.exit(result="switch")

    app = Application(
        layout=layout,
        key_bindings=kb,
        style=None,
        full_screen=False,
        mouse_support=True,
    )

    result = app.run()

    if isinstance(result, tuple) and result[0] == "save_new":
        text_to_save = result[1]
        os.system("clear")
        file_path = prompt("Save tab as: ", multiline=False)
        if file_path:
            try:
                with open(file_path, "w", encoding="utf-8") as f:
                    f.write(text_to_save)
                    if not text_to_save.endswith("\n"):
                        f.write("\n")
                old_name = tab_order[current_idx]
                tab_order[current_idx] = file_path
                tabs[file_path] = text_to_save
                del tabs[old_name]
            except Exception as e:
                print(f"Saving error: {e}")
                input("Press enter...")
