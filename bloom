#!/usr/bin/env python3

import os
import argparse
from colorama import Fore, Back, init
from prompt_toolkit import prompt
from prompt_toolkit.key_binding import KeyBindings

init(autoreset=True)

def arguments():
    parser = argparse.ArgumentParser(description="Argument check")
    parser.add_argument('my_arg', nargs='?', default=None)
    args = parser.parse_args()
    return args.my_arg if args.my_arg else None

tabs = {}
tab_order = []
current_idx = 0
version = "1.3.1"
running = True

# initialazing
initial_arg = arguments()
if initial_arg:
    if os.path.exists(initial_arg):
        try:
            with open(initial_arg, "r", encoding="utf-8") as f:
                tabs[initial_arg] = f.read()
        except Exception:
            tabs[initial_arg] = ""
    else:
        tabs[initial_arg] = ""
    tab_order.append(initial_arg)
else:
    tabs["new tab"] = ""
    tab_order.append("new tab")

# binds
kb = KeyBindings()

@kb.add("c-s")
def save_current_tab(event):
    global current_idx
    current_tab_name = tab_order[current_idx]
    current_text = event.app.current_buffer.text
    tabs[current_tab_name] = current_text

    if "new tab" in current_tab_name:
        event.app.exit(result=("save_new", current_text))
    else:
        try:
            with open(current_tab_name, "w", encoding="utf-8") as f:
                f.write(current_text)
                if not current_text.endswith("\n"):
                    f.write("\n")
            event.app.exit(result="refresh")
        except Exception:
            event.app.exit(result="refresh")

@kb.add("c-q")
def exit_editor(event):
    global running
    running = False
    event.app.exit(result="exit")

@kb.add("c-c")
def exit_no_save(event):
    global running
    running = False
    event.app.exit(result=None)

@kb.add("c-t")
def new_tab(event):
    global current_idx
    current_tab = tab_order[current_idx]
    tabs[current_tab] = event.app.current_buffer.text
    
    new_tab_name = f"new tab {len(tabs) + 1}"
    tabs[new_tab_name] = ""
    tab_order.append(new_tab_name)
    
    current_idx = len(tab_order) - 1
    event.app.exit(result="switch")

@kb.add("c-p")
def next_tab(event):
    global current_idx
    if len(tab_order) <= 1:
        return
    current_tab = tab_order[current_idx]
    tabs[current_tab] = event.app.current_buffer.text
    
    current_idx = (current_idx + 1) % len(tab_order)
    event.app.exit(result="switch")

while running:
    os.system("clear")    
    rendered_tabs = []
    for i, tab_name in enumerate(tab_order):
        if i == current_idx:
            rendered_tabs.append(f"{Fore.BLACK + Back.GREEN} {tab_name} {Fore.RESET}")
        else:
            rendered_tabs.append(f"{Fore.WHITE + Back.BLACK} {tab_name} {Fore.RESET}")
            
    tab_line = "  ".join(rendered_tabs)
    raw_len = len("  ".join(tab_order)) + (len(tab_order) * 2) 
    padding = max(0, os.get_terminal_size().columns - 15 - raw_len)
    
    print(f"{Fore.BLACK + Back.WHITE}Bloom {version}{Fore.RESET}  {tab_line}{Back.WHITE}{' ' * padding}{Fore.RESET}")

    current_tab_name = tab_order[current_idx]
    current_text = tabs[current_tab_name]
    
    result = prompt("", default=current_text, multiline=True, key_bindings=kb)
    
    if isinstance(result, tuple) and result[0] == "save_new":
        text_to_save = result[1]
        os.system("clear")
        file_path = prompt("Save tab as: ", multiline=False)
        
        if file_path:
            try:
                with open(file_path, "w", encoding="utf-8") as f:
                    f.write(text_to_save)
                    if not text_to_save.endswith("\n"):
                        f.write("\n")
                
                old_name = tab_order[current_idx]
                tab_order[current_idx] = file_path
                tabs[file_path] = text_to_save
                del tabs[old_name]
            except Exception as e:
                print(f"Saving error: {e}")
                input("Press enter...")
