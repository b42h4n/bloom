#!/usr/bin/env python3
import os
from prompt_toolkit import Application
from prompt_toolkit.buffer import Buffer
from prompt_toolkit.document import Document
from prompt_toolkit.key_binding import KeyBindings
from prompt_toolkit.layout.containers import HSplit, VSplit, Window
from prompt_toolkit.layout.controls import BufferControl, FormattedTextControl
from prompt_toolkit.layout.layout import Layout
from prompt_toolkit.layout.margins import NumberedMargin
from prompt_toolkit.widgets import TextArea
import argparse
from colorama import Fore, Back, Style

def arguments():
    parser = argparse.ArgumentParser(description="Argument check")
    parser.add_argument('my_arg', nargs='?', default=None)
    args = parser.parse_args()
    return args.my_arg if args.my_arg is not None else False

if arguments():
    args = arguments()
else:
    args = ""

os.system("clear")
version = "1.3"
initial_text = ""
if args:
    try:
        with open(args, "r", encoding="utf-8") as f:
            initial_text = f.read()
    except FileNotFoundError:
        open(args, "w").close()

text_area = TextArea(
    text=initial_text,
    multiline=True,
    scrollbar=True,
    line_numbers=True,
)

# Status
def get_status():
    row = text_area.document.cursor_position_row + 1
    col = text_area.document.cursor_position_col + 1
    return f"Bloom minimal {version}| Ctrl+S — Save and exit  |  Ctrl+Q — Quit without saving  |  Line {row}, Column {col}"

status_bar = Window(
    content=FormattedTextControl(get_status),
    height=1,
    style="reverse",
)

# Binds
kb = KeyBindings()
saved_text = [None]

@kb.add("c-s")
def save(event):
    saved_text[0] = text_area.text
    event.app.exit()

@kb.add("c-q")
def exit_no_save(event):
    saved_text[0] = None
    event.app.exit()

# Layout
layout = Layout(HSplit([text_area, status_bar]))

app = Application(layout=layout, key_bindings=kb, full_screen=True)
app.run()

# Saving
text = saved_text[0]
if text is not None:
    from prompt_toolkit import prompt
    file = prompt("Save to file: ", default=args, multiline=False)
    if file:
        try:
            with open(file, "w", encoding="utf-8") as f:
                f.write(text)
                if not text.endswith("\n"):
                    f.write("\n")
        except FileNotFoundError:
            pass
