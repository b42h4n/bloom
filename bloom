import os
os.system("clear")
size=os.get_terminal_size()
lines=[]
linescount=1
print(f"Bloom 1.0{" "*int((size.columns/2-9)-9)}new file")
while True:
    try:
        lines.append(input(f"{linescount}   "))
        linescount+=1
    except (EOFError, KeyboardInterrupt):
        try:
            file=input("\nSave to file: ")
            if not file:
                os.system("clear")
                print("canceled")
                break
            else:
                with open(file, "w", encoding="utf-8") as fil:
                    for i in lines:
                        fil.write(f"{i}\n")
                os.system("clear")
                break
        except (EOFError, KeyboardInterrupt):
            os.system("clear")
            print()
            break